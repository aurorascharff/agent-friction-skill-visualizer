# Vercel Blob (required — auto-provisioned via Vercel Marketplace)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# HMAC secret for signing draft IDs (required)
# Generate with: openssl rand -hex 32
INGEST_SECRET=your-secret-here

# Shared bearer token for the reports/triage API (required)
# Same value must be set on the DX Agent
REPORTS_API_TOKEN=your-token-here
